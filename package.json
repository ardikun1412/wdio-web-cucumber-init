{
  "name": "wdio-saucedemo-automation-framework",
  "version": "1.0.0",
  "description": "WebdriverIO Cucumber automation framework for SauceDemo with data-driven testing, Allure report, multi environment, GitHub Actions, Babel, and Selenium Grid.",
  "type": "module",
  "scripts": {
    "clean": "rm -rf allure-results allure-report",
    "test": "npm run clean && wdio run ./wdio.conf.js",
    "test:dev": "TEST_ENV=dev npm run test",
    "test:staging": "TEST_ENV=staging npm run test",
    "test:e2e": "TAGS='@e2e' npm run test:dev",
    "allure:generate": "npx allure generate allure-results -o allure-report",
    "allure:open": "npx allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "result:enrich": "node scripts/enrich-result.js",
    "upload:xray": "npm run result:enrich && node helper/jira/index.js",
    "grid:start": "docker compose up -d",
    "grid:stop": "docker compose down",
    "grid:open": "open http://localhost:4444",
    "grafana:start": "docker compose up -d prometheus pushgateway loki grafana",
    "grafana:stop": "docker compose stop prometheus pushgateway loki grafana",
    "grafana:open": "open http://localhost:3000"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "cross-env": "^10.1.0",
    "rimraf": "^6.1.3",
    "open-cli": "^9.0.0"
  },
  "devDependencies": {
    "@cucumber/gherkin": "^39.1.0",
    "@cucumber/messages": "^32.3.1",
    "@wdio/allure-reporter": "9.27.1",
    "@wdio/cli": "9.27.1",
    "@wdio/cucumber-framework": "9.27.0",
    "@wdio/local-runner": "9.27.1",
    "@wdio/spec-reporter": "9.27.1",
    "allure": "3.8.0",
    "dotenv": "17.2.3",
    "prom-client": "^15.1.0",
    "webdriverio": "9.27.1",
    "winston": "^3.17.0",
    "winston-loki": "^6.1.3"
  }
}
